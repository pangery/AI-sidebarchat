{
  "manifest_version": 3,
  "name": "AI Sidebar Chat",
  "short_name": "AI-sidebarchat",
  "version": "3.6.0",
  "description": "Side panel for ChatGPT, Gemini, Perplexity, Grok, Claude & more. Auto page context. Web mode needs no API key.",
  "homepage_url": "https://github.com/pangery/AI-sidebarchat",
  "minimum_chrome_version": "109",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "optional_permissions": ["sidePanel"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.perplexity.ai/*",
    "https://api.x.ai/*",
    "https://api.mistral.ai/*",
    "https://api.deepseek.com/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*",
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://openai.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://*.perplexity.ai/*",
    "https://grok.com/*",
    "https://*.x.ai/*",
    "https://claude.ai/*",
    "https://*.anthropic.com/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "https://*.deepseek.com/*",
    "https://chat.mistral.ai/*",
    "https://www.meta.ai/*",
    "https://poe.com/*",
    "https://huggingface.co/*",
    "https://you.com/*",
    "https://pi.ai/*",
    "https://chat.qwen.ai/*",
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "embed_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AI Sidebar Chat",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "sidebar_action": {
    "default_title": "AI Sidebar Chat",
    "default_panel": "panel.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Otevřít AI panel"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["browser.js", "providers.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-sidebarchat@jangergel",
      "strict_min_version": "109.0"
    }
  }
}
